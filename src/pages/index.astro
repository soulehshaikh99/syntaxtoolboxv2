---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import { homeMeta } from '@/data/pages/home.meta';
---

<DefaultLayout
  title={homeMeta.title}
  description={homeMeta.description}
  keywords={homeMeta.keywords}
  schema={homeMeta.schema}
  >
  <main class="flex flex-col items-center justify-center px-6 py-20 max-sm:py-12 gap-3 text-center">
    <span class="inline-flex items-center gap-1.5 px-3 py-[5px] rounded-full text-sm15 font-semibold text-accent" style="background:color-mix(in srgb, var(--accent) 10%, transparent)">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      Nav component preview
    </span>
    <h1 class="text-[1.75rem] max-sm:text-[1.25rem] font-semibold tracking-[-0.03em] text-text">Syntax Toolbox</h1>
    <p class="text-base text-muted max-w-[400px] leading-relaxed">Resize the window to see the responsive hamburger menu. Use the theme toggle in the top-right to switch between Light, Dark, and System modes.</p>
  </main>  
  <script>
    const html = document.documentElement;
    let currentTheme = localStorage.getItem('st-theme') || 'system';

    const ICONS = {
      light: `<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`,
      dark:  `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`,
      system:`<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`
    };

	function applyTheme(theme) {
		currentTheme = theme;
		html.setAttribute('data-theme', theme);
		localStorage.setItem('st-theme', theme);
		document.getElementById('themeIcon').innerHTML = ICONS[theme];
		document.querySelectorAll('.theme-option').forEach(b => b.classList.toggle('is-active', b.dataset.theme === theme));
		document.querySelectorAll('.mobile-theme-opt').forEach(b => b.classList.toggle('is-active', b.dataset.theme === theme));

		// Update theme-color meta
		const themeColorMeta = document.querySelector('meta[name="theme-color"]');
		const isDark = theme === 'dark' ||
			(theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
		themeColorMeta.setAttribute('content', isDark ? '#0d1117' : '#ffffff');
	}

    applyTheme(currentTheme);

    // Theme dropdown
    const themeTrigger  = document.getElementById('themeTrigger');
    const themeDropdown = document.getElementById('themeDropdown');

    function toggleDropdown(force) {
      const open = force !== undefined ? force : !themeDropdown.classList.contains('is-open');
      themeDropdown.classList.toggle('is-open', open);
      themeTrigger.setAttribute('aria-expanded', open);
    }

    themeTrigger.addEventListener('click', e => { e.stopPropagation(); closeMobileMenu(); toggleDropdown(); });
    document.querySelectorAll('.theme-option').forEach(b => b.addEventListener('click', () => { applyTheme(b.dataset.theme); toggleDropdown(false); }));
    document.addEventListener('click', e => { if (!document.getElementById('themeBtn').contains(e.target)) toggleDropdown(false); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { toggleDropdown(false); closeMobileMenu(); } });

    // Mobile menu
    const hamburger     = document.getElementById('hamburger');
    const mobileMenu    = document.getElementById('mobileMenu');
    const overlay       = document.getElementById('overlay');
    const hamburgerIcon = document.getElementById('hamburgerIcon');

    const OPEN_ICON  = `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`;
    const CLOSE_ICON = `<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>`;

    function closeMobileMenu() {
      mobileMenu.classList.remove('is-open');
      overlay.classList.remove('is-open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburgerIcon.innerHTML = CLOSE_ICON;
    }

    hamburger.addEventListener('click', e => {
      e.stopPropagation();
      toggleDropdown(false);
      const open = mobileMenu.classList.toggle('is-open');
      overlay.classList.toggle('is-open', open);
      hamburger.setAttribute('aria-expanded', open);
      hamburgerIcon.innerHTML = open ? OPEN_ICON : CLOSE_ICON;
    });

    overlay.addEventListener('click', closeMobileMenu);
    document.querySelectorAll('.mobile-theme-opt').forEach(b => b.addEventListener('click', () => applyTheme(b.dataset.theme)));
    document.getElementById('mobileMenuLink').addEventListener('click', closeMobileMenu);
    document.getElementById('mobileChangelogLink').addEventListener('click', closeMobileMenu);

    // Search
    document.addEventListener('keydown', e => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); document.getElementById('searchBtn').focus(); }
    });
    document.getElementById('searchBtn').addEventListener('click', () => console.log('Search — wire up modal here.'));
    document.getElementById('searchIconBtn').addEventListener('click', () => console.log('Mobile search — wire up modal here.'));
  </script>
</DefaultLayout>