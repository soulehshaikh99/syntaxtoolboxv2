---
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { site } from '../config/site'

import '../styles/global.css'

const gaTagId = import.meta.env.PUBLIC_GA_TAG_ID;
const adsenseId = import.meta.env.PUBLIC_ADSENSE_ID;
const indexingConfig = import.meta.env.PUBLIC_INDEXING_CONFIG;

const { title, description, keywords, schema } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="system">

<head>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaTagId}`}></script>
    <script is:inline define:vars={{ gaTagId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', gaTagId);
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-adsense-account" content={adsenseId}>
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <!-- Canonical URL -->
    <link rel="canonical" href={site.home()} />
    
    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site.home()} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={site.asset('/assets/indexing/og-image.jpg')} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="Syntax Toolbox" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={site.asset('/assets/indexing/og-image.jpg')} />
    <meta name="twitter:site" content="@syntaxtoolbox" />
    <meta name="twitter:creator" content="@syntaxtoolbox" />

    <!-- Favicon for browser tabs -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />

    <!-- Apple Touch Icon for iOS home screen bookmarks -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Web App Manifest for Progressive Web Apps (PWAs) -->
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Define theme color for browser UI elements -->
    <meta name="theme-color" content="#ffffff">

    <!-- Set the name of the web app when added to the home screen on iOS & Android -->
    <meta name="apple-mobile-web-app-title" content="Syntax Toolbox">
    <meta name="application-name" content="Syntax Toolbox">

    <!-- Allow search engines to index this page and follow links -->
    <meta name="robots" content={indexingConfig}>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <meta name="keywords" content={keywords}>

    {schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
</head>

<body class="font-sans bg-surface text-text min-h-screen">
    <Header />
    <slot />
    <Footer />
</body>
</html>