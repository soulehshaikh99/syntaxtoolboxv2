---
import LogoIcon from '@/components/icons/LogoIcon.astro';
import SunIcon from '@/components/icons/SunIcon.astro';
import { Search, Monitor, Moon, Menu, Check, LayoutGrid, ScrollText } from '@lucide/astro';
---

<!-- ── Nav ── -->
<header class="sticky top-0 z-50 h-nav bg-bg border-b border-border shadow-nav transition-colors duration-200">
    <div class="max-w-layout mx-auto h-full px-6 flex items-center gap-4 max-md:px-4">
        <!-- Brand -->
        <a href="/" class="flex items-center gap-2.5 no-underline shrink-0 mr-1 max-md:mr-0" aria-label="Syntax Toolbox home">
            <span class="w-[34px] h-[34px] grid place-items-center shrink-0" aria-hidden="true">
                <LogoIcon class="logo-svg w-[34px] h-[34px] block" />
            </span>
            <span class="text-base font-semibold text-text tracking-tight whitespace-nowrap max-[360px]:hidden">Syntax Toolbox</span>
        </a>
        <!-- Spacer -->
        <div class="flex-1"></div>
        <!-- Desktop nav links -->
        <a href="/tools"     class="max-md:hidden p-2 text-md font-medium text-muted no-underline whitespace-nowrap shrink-0 transition-colors duration-200 hover:text-text">All Tools</a>
        <a href="/changelog" class="max-md:hidden p-2 text-md font-medium text-muted no-underline whitespace-nowrap shrink-0 transition-colors duration-200 hover:text-text">Changelog</a>
        <!-- Desktop: search + theme grouped -->
        <div class="max-md:hidden flex items-center gap-2">
            <!-- Search bar -->
            <div class="search-bar flex items-center gap-2 h-[38px] px-3 bg-surface border border-border rounded-theme cursor-pointer transition-all duration-200 min-w-[240px] max-w-[280px] flex-1 select-none"
                role="button" tabindex="0" aria-label="Search tools (Ctrl+K)" id="searchBtn">
                <span class="text-muted shrink-0" aria-hidden="true">
                    <Search class="w-[15px] h-[15px] block" />
                </span>
                <span class="text-base15 text-muted flex-1 whitespace-nowrap">Search tools…</span>
                <span class="flex items-center gap-0.5 shrink-0" aria-hidden="true">
                <kbd class="inline-flex items-center justify-center h-5 px-[5px] bg-elevated border border-border rounded-[5px] font-sans text-2xs text-muted leading-none">Ctrl</kbd>
                <kbd class="inline-flex items-center justify-center h-5 px-[5px] bg-elevated border border-border rounded-[5px] font-sans text-2xs text-muted leading-none">K</kbd>
                </span>
            </div>
            <!-- Theme button -->
            <div class="relative shrink-0" id="themeBtn">
                <button class="flex items-center justify-center w-[38px] h-[38px] rounded-theme border border-border bg-surface text-icon cursor-pointer transition-all duration-200 hover:border-accent hover:text-accent hover:bg-elevated" aria-label="Change theme" aria-haspopup="true" aria-expanded="false" id="themeTrigger">
                    <Monitor id="themeIcon" class="w-[17px] h-[17px] pointer-events-none" />
                </button>
                <!-- Dropdown -->
                <div class="theme-dropdown absolute top-[calc(100%+8px)] right-0 min-w-[150px] bg-elevated border border-border rounded-theme shadow-dropdown p-1.5 flex flex-col gap-0.5"
                    id="themeDropdown" role="menu">
                    <button class="theme-option flex items-center gap-2.5 px-2.5 py-2 rounded-[7px] text-base15 font-medium text-muted cursor-pointer border-none bg-transparent w-full text-left transition-all duration-200 hover:bg-surface hover:text-text"
                        data-theme="light" role="menuitem">
                        <SunIcon class="w-[15px] h-[15px] shrink-0" />
                        Light
                        <Check class="check-icon ml-auto opacity-0 text-accent w-[15px] h-[15px]" stroke-width="2.5" />
                    </button>
                    <button class="theme-option flex items-center gap-2.5 px-2.5 py-2 rounded-[7px] text-base15 font-medium text-muted cursor-pointer border-none bg-transparent w-full text-left transition-all duration-200 hover:bg-surface hover:text-text"
                        data-theme="dark" role="menuitem">
                        <Moon class="w-[15px] h-[15px] shrink-0" />
                        Dark
                        <Check class="check-icon ml-auto opacity-0 text-accent w-[15px] h-[15px]" stroke-width="2.5" />
                    </button>
                    <button class="theme-option flex items-center gap-2.5 px-2.5 py-2 rounded-[7px] text-base15 font-medium text-muted cursor-pointer border-none bg-transparent w-full text-left transition-all duration-200 hover:bg-surface hover:text-text"
                        data-theme="system" role="menuitem">
                        <Monitor class="w-[15px] h-[15px] shrink-0" />
                        System
                        <Check class="check-icon ml-auto opacity-0 text-accent w-[15px] h-[15px]" stroke-width="2.5" />
                    </button>
                </div>
            </div>
        </div>
        <!-- Mobile: search icon + hamburger -->
        <div class="hidden max-md:flex items-center gap-2">
            <button class="flex items-center justify-center w-[38px] h-[38px] rounded-theme border border-border bg-surface text-icon cursor-pointer shrink-0 transition-all duration-200 hover:border-accent hover:text-accent"
                id="searchIconBtn" aria-label="Search tools">
                <Search class="w-[17px] h-[17px] pointer-events-none" />
            </button>
            <button class="flex items-center justify-center w-[38px] h-[38px] rounded-theme border border-border bg-surface text-icon cursor-pointer shrink-0 transition-all duration-200 hover:border-accent hover:text-accent"
                id="hamburger" aria-label="Open menu" aria-expanded="false">
                <Menu id="hamburgerIcon" class="w-[18px] h-[18px] pointer-events-none" />
            </button>
        </div>
    </div>
</header>
<!-- ── Mobile menu ── -->
<nav class="mobile-menu fixed top-[64px] left-0 right-0 z-40 bg-elevated border-b border-border shadow-dropdown px-4 pt-3 pb-5 flex flex-col gap-1"
    id="mobileMenu" aria-label="Mobile navigation">
    <a href="/tools" class="flex items-center gap-2.5 px-3 py-[11px] rounded-theme text-md font-medium text-muted no-underline transition-all duration-200 hover:bg-surface hover:text-text"
        id="mobileMenuLink">
        <LayoutGrid class="w-[17px] h-[17px]" />
        All Tools
    </a>
    <a href="/changelog" class="flex items-center gap-2.5 px-3 py-[11px] rounded-theme text-md font-medium text-muted no-underline transition-all duration-200 hover:bg-surface hover:text-text"
        id="mobileChangelogLink">
        <ScrollText class="w-[17px] h-[17px]" />
        Changelog
    </a>
    <div class="h-px bg-border my-1.5"></div>
    <p class="text-2xs font-semibold text-muted uppercase tracking-[0.06em] px-3 py-1">Theme</p>
    <div class="flex gap-1.5 px-1">
        <button class="mobile-theme-opt flex-1 flex flex-col items-center gap-1.5 px-2 py-2.5 rounded-theme text-sm15 font-medium text-muted cursor-pointer border border-border bg-surface transition-all duration-200 hover:border-accent hover:text-accent"
            data-theme="light">
            <SunIcon class="w-[18px] h-[18px]" />
            Light
        </button>
        <button class="mobile-theme-opt flex-1 flex flex-col items-center gap-1.5 px-2 py-2.5 rounded-theme text-sm15 font-medium text-muted cursor-pointer border border-border bg-surface transition-all duration-200 hover:border-accent hover:text-accent"
            data-theme="dark">
            <Moon class="w-[18px] h-[18px]" />
            Dark
        </button>
        <button class="mobile-theme-opt flex-1 flex flex-col items-center gap-1.5 px-2 py-2.5 rounded-theme text-sm15 font-medium text-muted cursor-pointer border border-border bg-surface transition-all duration-200 hover:border-accent hover:text-accent"
            data-theme="system">
            <Monitor class="w-[18px] h-[18px]" />
            System
        </button>
    </div>
</nav>
<!-- Overlay -->
<div class="overlay fixed inset-0 z-30 bg-black/25" id="overlay"></div>