---
import LogoIcon from '@/components/icons/LogoIcon.astro';
import XLogo from '@/components/icons/social/XLogo.astro';
import InstagramLogo from '@/components/icons/social/InstagramLogo.astro';
import ThreadsLogo from '@/components/icons/social/ThreadsLogo.astro';
import FacebookLogo from '@/components/icons/social/FacebookLogo.astro';
import LinkedInLogo from '@/components/icons/social/LinkedInLogo.astro';
import PinterestLogo from '@/components/icons/social/PinterestLogo.astro';
import GitHubLogo from '@/components/icons/social/GitHubLogo.astro';
import RedditLogo from '@/components/icons/social/RedditLogo.astro';
---

<footer class="bg-bg border-t border-border mt-auto px-6 pt-20 pb-12 max-[900px]:pt-[60px] max-[900px]:pb-10 max-[540px]:px-4 max-[540px]:pt-12 max-[540px]:pb-8">
    <div class="max-w-layout mx-auto grid grid-cols-[1.8fr_repeat(3,1fr)] gap-16 max-[900px]:grid-cols-2 max-[900px]:gap-12 max-[540px]:grid-cols-1 max-[540px]:gap-8">
        <!-- Brand col -->
        <div class="max-[900px]:col-span-2 max-[540px]:col-span-1">
            <a href="/" class="flex items-center gap-2.5 no-underline mb-4">
                <span class="w-[30px] h-[30px] shrink-0">
                    <LogoIcon class="logo-svg w-[30px] h-[30px] block" />
                </span>
                <span class="text-md font-semibold text-text tracking-tight">Syntax Toolbox</span>
            </a>
            <p class="text-base15 text-muted leading-[1.7] mb-7">From conversions to calculations and beyond, Syntax Toolbox is your free, smart assistant that handles it all. Forget about switching apps or paying for premium features, this is the only toolbox you'll ever want.</p>
            <!-- Social icons -->
            <div class="flex flex-wrap gap-2.5">
                <a href="https://x.com/syntaxtoolbox" target="_blank" rel="noopener noreferrer" class="footer-social flex items-center justify-center w-10 h-10 rounded-[10px] border border-border bg-surface text-muted no-underline shrink-0 transition-all duration-200 hover:border-accent hover:text-accent" style="--hover-bg:color-mix(in srgb, var(--accent) 6%, transparent)" aria-label="Follow us on X(Twitter)">
                    <XLogo size={20} />
                </a>
                <a href="https://www.instagram.com/syntaxtoolbox/" target="_blank" rel="noopener noreferrer" class="footer-social flex items-center justify-center w-10 h-10 rounded-[10px] border border-border bg-surface text-muted no-underline shrink-0 transition-all duration-200 hover:border-accent hover:text-accent" aria-label="Follow us on Instagram">
                    <InstagramLogo size={20} />
                </a>
                <a href="https://www.threads.com/@syntaxtoolbox" target="_blank" rel="noopener noreferrer" class="footer-social flex items-center justify-center w-10 h-10 rounded-[10px] border border-border bg-surface text-muted no-underline shrink-0 transition-all duration-200 hover:border-accent hover:text-accent" aria-label="Follow us on Threads">
                    <ThreadsLogo size={20} />
                </a>
                <a href="https://www.facebook.com/people/Syntax-Toolbox/61580527934984/" target="_blank" rel="noopener noreferrer" class="footer-social flex items-center justify-center w-10 h-10 rounded-[10px] border border-border bg-surface text-muted no-underline shrink-0 transition-all duration-200 hover:border-accent hover:text-accent" aria-label="Follow us on Facebook">
                    <FacebookLogo size={20} />
                </a>
                <a href="https://www.linkedin.com/company/syntax-toolbox" target="_blank" rel="noopener noreferrer" class="footer-social flex items-center justify-center w-10 h-10 rounded-[10px] border border-border bg-surface text-muted no-underline shrink-0 transition-all duration-200 hover:border-accent hover:text-accent" aria-label="Follow us on LinkedIn">
                    <LinkedInLogo size={20} />
                </a>
                <a href="https://in.pinterest.com/syntaxtoolbox/" target="_blank" rel="noopener noreferrer" class="footer-social flex items-center justify-center w-10 h-10 rounded-[10px] border border-border bg-surface text-muted no-underline shrink-0 transition-all duration-200 hover:border-accent hover:text-accent" aria-label="Follow us on Pinterest">
                    <PinterestLogo size={20} />
                </a>
                <a href="https://github.com/syntaxtoolbox" target="_blank" rel="noopener noreferrer" class="footer-social flex items-center justify-center w-10 h-10 rounded-[10px] border border-border bg-surface text-muted no-underline shrink-0 transition-all duration-200 hover:border-accent hover:text-accent" aria-label="Follow us on GitHub">
                    <GitHubLogo size={20} />
                </a>
                <a href="https://www.reddit.com/user/SyntaxToolbox/" target="_blank" rel="noopener noreferrer" class="footer-social flex items-center justify-center w-10 h-10 rounded-[10px] border border-border bg-surface text-muted no-underline shrink-0 transition-all duration-200 hover:border-accent hover:text-accent" aria-label="Follow us on Reddit">
                    <RedditLogo size={20} />
                </a>
            </div>
        </div>
        <!-- Resources -->
        <div>
            <p class="text-2xs font-semibold text-muted uppercase tracking-[0.07em] mb-5">Resources</p>
            <ul class="flex flex-col gap-3.5 list-none">
                <li><a href="/tools" class="text-base15 text-muted no-underline transition-colors duration-200 hover:text-text">Tools</a></li>
            </ul>
        </div>
        <!-- Company -->
        <div>
            <p class="text-2xs font-semibold text-muted uppercase tracking-[0.07em] mb-5">Company</p>
            <ul class="flex flex-col gap-3.5 list-none">
                <li><a href="/about"     class="text-base15 text-muted no-underline transition-colors duration-200 hover:text-text">About Us</a></li>
                <li><a href="/contact"   class="text-base15 text-muted no-underline transition-colors duration-200 hover:text-text">Contact Us</a></li>
                <li><a href="/changelog" class="text-base15 text-muted no-underline transition-colors duration-200 hover:text-text">Changelog</a></li>
                <li><a href="/sitemap"   class="text-base15 text-muted no-underline transition-colors duration-200 hover:text-text">Sitemap</a></li>
            </ul>
        </div>
        <!-- Legal -->
        <div>
            <p class="text-2xs font-semibold text-muted uppercase tracking-[0.07em] mb-5">Legal</p>
            <ul class="flex flex-col gap-3.5 list-none">
                <li><a href="/privacy"    class="text-base15 text-muted no-underline transition-colors duration-200 hover:text-text">Privacy Policy</a></li>
                <li><a href="/terms"      class="text-base15 text-muted no-underline transition-colors duration-200 hover:text-text">Terms Of Use</a></li>
                <li><a href="/disclaimer" class="text-base15 text-muted no-underline transition-colors duration-200 hover:text-text">Disclaimer</a></li>
            </ul>
        </div>
    </div>
    <!-- Bottom bar -->
    <div class="max-w-layout mx-auto mt-14 pt-7 border-t border-border flex items-center justify-between gap-4 flex-wrap max-[900px]:mt-11 max-[900px]:pt-6 max-[540px]:mt-9 max-[540px]:pt-5">
        <p class="text-sm15 text-muted">&copy; 2026 Syntax Toolbox. All Rights Reserved.</p>
    </div>
</footer>